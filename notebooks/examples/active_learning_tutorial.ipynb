    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"a1b2c3d4\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Active Learning with probly\\n\",\n",
    "    \"\\n\",\n",
    "    \"This notebook demonstrates `probly.evaluation.active_learning.active_learning_loop` on two tasks:\\n\",\n",
    "    \"\\n\",\n",
    "    \"1. **Classification** — `make_moons` (2D): visualise queried points and compare uncertainty vs. random sampling.\\n\",\n",
    "    \"2. **Regression** — synthetic gap data: variance-based querying with a bootstrap MLP ensemble.\\n\",\n",
    "    \"\\n\",\n",
    "    \"The core idea: instead of labelling points at random, we ask the model *which unlabelled points it is most uncertain about* and label those first.\\n\",\n",
    "    \"This should yield a faster-rising learning curve and a higher normalised AUC.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"b2c3d4e5\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-26T13:42:57.554026383Z\",\n",
    "     \"start_time\": \"2026-03-26T13:42:55.754941799Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"import warnings\\n\",\n",
    "    \"\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"from sklearn.base import BaseEstimator, RegressorMixin\\n\",\n",
    "    \"from sklearn.datasets import make_moons\\n\",\n",
    "    \"from sklearn.ensemble import RandomForestClassifier\\n\",\n",
    "    \"from sklearn.model_selection import train_test_split\\n\",\n",
    "    \"from sklearn.neural_network import MLPRegressor\\n\",\n",
    "    \"from sklearn.preprocessing import StandardScaler\\n\",\n",
    "    \"\\n\",\n",
    "    \"from probly.evaluation.active_learning import active_learning_loop\\n\",\n",
    "    \"\\n\",\n",
    "    \"warnings.filterwarnings(\\\"ignore\\\")\\n\",\n",
    "    \"SEED = 0\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 1\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"c3d4e5f6\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## Helper utilities\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"d4e5f6a7\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-26T13:42:57.623528320Z\",\n",
    "     \"start_time\": \"2026-03-26T13:42:57.573462806Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"from collections.abc import Callable\\n\",\n",
    "    \"\\n\",\n",
    "    \"import numpy.typing as npt\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def make_random_query_fn(seed: int | None = None) -> Callable:\\n\",\n",
    "    \"    \\\"\\\"\\\"Return a query function that assigns uniformly random scores (random baseline).\\\"\\\"\\\"\\n\",\n",
    "    \"    rng = np.random.default_rng(seed)\\n\",\n",
    "    \"    return lambda outputs: rng.random(len(outputs))\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def plot_learning_curves(\\n\",\n",
    "    \"    curves: dict[str, list[float]],\\n\",\n",
    "    \"    naucs: dict[str, float],\\n\",\n",
    "    \"    ylabel: str,\\n\",\n",
    "    \"    title: str,\\n\",\n",
    "    \") -> None:\\n\",\n",
    "    \"    fig, ax = plt.subplots(figsize=(7, 4))\\n\",\n",
    "    \"    for label, scores in curves.items():\\n\",\n",
    "    \"        nauc = naucs.get(label, float(\\\"nan\\\"))\\n\",\n",
    "    \"        ax.plot(scores, marker=\\\"o\\\", markersize=4, label=f\\\"{label} (NAUC={nauc:.2f})\\\")\\n\",\n",
    "    \"    ax.set_xlabel(\\\"Active learning iteration\\\")\\n\",\n",
    "    \"    ax.set_ylabel(ylabel)\\n\",\n",
    "    \"    ax.set_title(title)\\n\",\n",
    "    \"    ax.legend()\\n\",\n",
    "    \"    ax.grid(alpha=0.3)\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"    plt.show()\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 2\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"e5f6a7b8\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"---\\n\",\n",
    "    \"## 1. Classification — `make_moons` (2D)\\n\",\n",
    "    \"\\n\",\n",
    "    \"A two-moon dataset lets us visualise the query process directly.\\n\",\n",
    "    \"We hold out 30 % as a test set and compare:\\n\",\n",
    "    \"- **Uncertainty sampling** (total entropy, default for deterministic classifiers)\\n\",\n",
    "    \"- **Random sampling** (baseline)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"f6a7b8c9\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-26T13:37:52.819149611Z\",\n",
    "     \"start_time\": \"2026-03-26T13:37:52.681368386Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"X_moons, y_moons = make_moons(n_samples=300, noise=0.25, random_state=SEED)\\n\",\n",
    "    \"X_moons = StandardScaler().fit_transform(X_moons)\\n\",\n",
    "    \"X_train_cls, X_test_cls, y_train_cls, y_test_cls = train_test_split(X_moons, y_moons, test_size=0.3, random_state=SEED)\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.figure(figsize=(5, 4))\\n\",\n",
    "    \"plt.scatter(X_train_cls[:, 0], X_train_cls[:, 1], c=y_train_cls, cmap=\\\"bwr\\\", alpha=0.6, s=20, label=\\\"train pool\\\")\\n\",\n",
    "    \"plt.scatter(X_test_cls[:, 0], X_test_cls[:, 1], c=y_test_cls, cmap=\\\"bwr\\\", alpha=0.2, s=10, marker=\\\"x\\\", label=\\\"test\\\")\\n\",\n",
    "    \"plt.title(\\\"make_moons — train pool and test set\\\")\\n\",\n",
    "    \"plt.gca().set_aspect(\\\"equal\\\", adjustable=\\\"box\\\")\\n\",\n",
    "    \"plt.legend(fontsize=8)\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"data\": {\n",
    "      \"text/plain\": [\n",
    "       \"<Figure size 500x400 with 1 Axes>\"\n",
    "      ],\n",
    "      \"image/png\": \"\"\n",
    "     },\n",
    "     \"metadata\": {},\n",
    "     \"output_type\": \"display_data\",\n",
    "     \"jetTransient\": {\n",
    "      \"display_id\": null\n",
    "     }\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 4\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"a7b8c9d0\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-26T13:37:54.615836056Z\",\n",
    "     \"start_time\": \"2026-03-26T13:37:53.387912946Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"POOL_SIZE = 10\\n\",\n",
    "    \"N_ITER = 10\\n\",\n",
    "    \"\\n\",\n",
    "    \"X_lab_al, y_lab_al, scores_al, nauc_al = active_learning_loop(\\n\",\n",
    "    \"    RandomForestClassifier(n_estimators=100, random_state=SEED),\\n\",\n",
    "    \"    X_train_cls,\\n\",\n",
    "    \"    y_train_cls,\\n\",\n",
    "    \"    X_test_cls,\\n\",\n",
    "    \"    y_test_cls,\\n\",\n",
    "    \"    metric=\\\"accuracy\\\",\\n\",\n",
    "    \"    pool_size=POOL_SIZE,\\n\",\n",
    "    \"    n_iterations=N_ITER,\\n\",\n",
    "    \"    seed=SEED,\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"X_lab_rand, y_lab_rand, scores_rand, nauc_rand = active_learning_loop(\\n\",\n",
    "    \"    RandomForestClassifier(n_estimators=100, random_state=SEED),\\n\",\n",
    "    \"    X_train_cls,\\n\",\n",
    "    \"    y_train_cls,\\n\",\n",
    "    \"    X_test_cls,\\n\",\n",
    "    \"    y_test_cls,\\n\",\n",
    "    \"    metric=\\\"accuracy\\\",\\n\",\n",
    "    \"    query_fn=make_random_query_fn(SEED),\\n\",\n",
    "    \"    pool_size=POOL_SIZE,\\n\",\n",
    "    \"    n_iterations=N_ITER,\\n\",\n",
    "    \"    seed=SEED,\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Uncertainty sampling — final accuracy: {scores_al[-1]:.3f}, NAUC: {nauc_al:.3f}\\\")\\n\",\n",
    "    \"print(f\\\"Random sampling      — final accuracy: {scores_rand[-1]:.3f}, NAUC: {nauc_rand:.3f}\\\")\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Uncertainty sampling — final accuracy: 0.978, NAUC: 0.929\\n\",\n",
    "      \"Random sampling      — final accuracy: 0.889, NAUC: 0.876\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 5\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"b8c9d0e1\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-26T13:37:56.513777581Z\",\n",
    "     \"start_time\": \"2026-03-26T13:37:56.402086155Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"plot_learning_curves(\\n\",\n",
    "    \"    {\\n\",\n",
    "    \"        \\\"Uncertainty (margin sampling)\\\": scores_al,\\n\",\n",
    "    \"        \\\"Random baseline\\\": scores_rand,\\n\",\n",
    "    \"    },\\n\",\n",
    "    \"    naucs={\\n\",\n",
    "    \"        \\\"Uncertainty (margin sampling)\\\": nauc_al,\\n\",\n",
    "    \"        \\\"Random baseline\\\": nauc_rand,\\n\",\n",
    "    \"    },\\n\",\n",
    "    \"    ylabel=\\\"Test accuracy\\\",\\n\",\n",
    "    \"    title=\\\"make_moons — RandomForestClassifier\\\",\\n\",\n",
    "    \")\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"data\": {\n",
    "      \"text/plain\": [\n",
    "       \"<Figure size 700x400 with 1 Axes>\"\n",
    "      ],\n",
    "      \"image/png\": \"\"\n",
    "     },\n",
    "     \"metadata\": {},\n",
    "     \"output_type\": \"display_data\",\n",
    "     \"jetTransient\": {\n",
    "      \"display_id\": null\n",
    "     }\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 6\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"7mddzs7xlgn\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": \"### Averaged over multiple runs\\n\\nA single active learning curve can be very noisy — the initial labelled set and the order of queries both depend on the random seed.\\nWe run 10 independent seeds and show the **mean ± 95 % confidence band** for each strategy.\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"9t84wex4q6\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-26T13:38:10.635612818Z\",\n",
    "     \"start_time\": \"2026-03-26T13:37:58.933876581Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"N_RUNS = 10\\n\",\n",
    "    \"\\n\",\n",
    "    \"all_scores_al = []\\n\",\n",
    "    \"all_scores_rand = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"for run_seed in range(N_RUNS):\\n\",\n",
    "    \"    _, _, s_al, _ = active_learning_loop(\\n\",\n",
    "    \"        RandomForestClassifier(n_estimators=100, random_state=run_seed),\\n\",\n",
    "    \"        X_train_cls,\\n\",\n",
    "    \"        y_train_cls,\\n\",\n",
    "    \"        X_test_cls,\\n\",\n",
    "    \"        y_test_cls,\\n\",\n",
    "    \"        metric=\\\"accuracy\\\",\\n\",\n",
    "    \"        pool_size=POOL_SIZE,\\n\",\n",
    "    \"        n_iterations=N_ITER,\\n\",\n",
    "    \"        seed=run_seed,\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    _, _, s_rand, _ = active_learning_loop(\\n\",\n",
    "    \"        RandomForestClassifier(n_estimators=100, random_state=run_seed),\\n\",\n",
    "    \"        X_train_cls,\\n\",\n",
    "    \"        y_train_cls,\\n\",\n",
    "    \"        X_test_cls,\\n\",\n",
    "    \"        y_test_cls,\\n\",\n",
    "    \"        metric=\\\"accuracy\\\",\\n\",\n",
    "    \"        query_fn=make_random_query_fn(run_seed),\\n\",\n",
    "    \"        pool_size=POOL_SIZE,\\n\",\n",
    "    \"        n_iterations=N_ITER,\\n\",\n",
    "    \"        seed=run_seed,\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    all_scores_al.append(s_al)\\n\",\n",
    "    \"    all_scores_rand.append(s_rand)\\n\",\n",
    "    \"\\n\",\n",
    "    \"scores_al_arr = np.array(all_scores_al)  # (N_RUNS, N_ITER)\\n\",\n",
    "    \"scores_rand_arr = np.array(all_scores_rand)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def ci95(arr: npt.NDArray) -> tuple[npt.NDArray, npt.NDArray]:\\n\",\n",
    "    \"    \\\"\\\"\\\"Return mean and half-width of 95 % confidence interval.\\\"\\\"\\\"\\n\",\n",
    "    \"    mean = arr.mean(axis=0)\\n\",\n",
    "    \"    half = 1.96 * arr.std(axis=0) / np.sqrt(len(arr))\\n\",\n",
    "    \"    return mean, half\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"mean_al, ci_al = ci95(scores_al_arr)\\n\",\n",
    "    \"mean_rand, ci_rand = ci95(scores_rand_arr)\\n\",\n",
    "    \"\\n\",\n",
    "    \"iters = np.arange(N_ITER)\\n\",\n",
    "    \"fig, ax = plt.subplots(figsize=(7, 4))\\n\",\n",
    "    \"for mean, ci, label, color in [\\n\",\n",
    "    \"    (mean_al, ci_al, \\\"Uncertainty (margin sampling)\\\", \\\"steelblue\\\"),\\n\",\n",
    "    \"    (mean_rand, ci_rand, \\\"Random baseline\\\", \\\"tomato\\\"),\\n\",\n",
    "    \"]:\\n\",\n",
    "    \"    ax.plot(iters, mean, marker=\\\"o\\\", markersize=4, label=label, color=color)\\n\",\n",
    "    \"    ax.fill_between(iters, mean - ci, mean + ci, alpha=0.2, color=color)\\n\",\n",
    "    \"\\n\",\n",
    "    \"ax.set_xlabel(\\\"Active learning iteration\\\")\\n\",\n",
    "    \"ax.set_ylabel(\\\"Test accuracy\\\")\\n\",\n",
    "    \"ax.set_title(f\\\"make_moons — RandomForestClassifier ({N_RUNS} runs, mean ± 95 % CI)\\\")\\n\",\n",
    "    \"ax.legend()\\n\",\n",
    "    \"ax.grid(alpha=0.3)\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"data\": {\n",
    "      \"text/plain\": [\n",
    "       \"<Figure size 700x400 with 1 Axes>\"\n",
    "      ],\n",
    "      \"image/png\": \"\"\n",
    "     },\n",
    "     \"metadata\": {},\n",
    "     \"output_type\": \"display_data\",\n",
    "     \"jetTransient\": {\n",
    "      \"display_id\": null\n",
    "     }\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 7\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": 11,\n",
    "   \"id\": \"c9d0e1f2\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-26T13:17:41.079291520Z\",\n",
    "     \"start_time\": \"2026-03-26T13:17:40.925052782Z\"\n",
    "    }\n",
    "   },\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"data\": {\n",
    "      \"image/png\": \"\",\n",
    "      \"text/plain\": [\n",
    "       \"<Figure size 1100x400 with 2 Axes>\"\n",
    "      ]\n",
    "     },\n",
    "     \"jetTransient\": {\n",
    "      \"display_id\": null\n",
    "     },\n",
    "     \"metadata\": {},\n",
    "     \"output_type\": \"display_data\"\n",
    "    }\n",
    "   ],\n",
    "   \"source\": [\n",
    "    \"# Visualise which train-pool points were queried\\n\",\n",
    "    \"initial_n = POOL_SIZE\\n\",\n",
    "    \"queried_al = X_lab_al[initial_n:]\\n\",\n",
    "    \"queried_rand = X_lab_rand[initial_n:]\\n\",\n",
    "    \"\\n\",\n",
    "    \"fig, axes = plt.subplots(1, 2, figsize=(11, 4), sharex=True, sharey=True)\\n\",\n",
    "    \"for ax, queried, title in zip(\\n\",\n",
    "    \"    axes,\\n\",\n",
    "    \"    [queried_al, queried_rand],\\n\",\n",
    "    \"    [\\\"Uncertainty sampling (queried)\\\", \\\"Random sampling (queried)\\\"],\\n\",\n",
    "    \"    strict=False,\\n\",\n",
    "    \"):\\n\",\n",
    "    \"    ax.scatter(X_train_cls[:, 0], X_train_cls[:, 1], c=\\\"lightgrey\\\", s=15, zorder=1)\\n\",\n",
    "    \"    ax.scatter(queried[:, 0], queried[:, 1], c=\\\"steelblue\\\", s=25, zorder=2, label=\\\"queried\\\")\\n\",\n",
    "    \"    ax.set_title(title)\\n\",\n",
    "    \"    ax.set_aspect(\\\"equal\\\", adjustable=\\\"box\\\")\\n\",\n",
    "    \"    ax.legend(fontsize=8)\\n\",\n",
    "    \"plt.suptitle(\\\"Queried train-pool points after all iterations\\\")\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"d0e1f2a3\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"Uncertainty sampling concentrates queries near the decision boundary, while random sampling spreads them uniformly across the pool.\\n\",\n",
    "    \"\\n\",\n",
    "    \"---\\n\",\n",
    "    \"## 2. Regression — synthetic gap data\\n\",\n",
    "    \"\\n\",\n",
    "    \"A 1-D dataset with a deliberate gap in `[-1, 1]` (no training data there).\\n\",\n",
    "    \"We use a **bootstrap MLP ensemble**: each `predict` call draws from a random member, making the model stochastic.\\n\",\n",
    "    \"The default regression query function selects the points with the highest **variance across stochastic forward passes**, which should focus queries on the gap region early on.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": 7,\n",
    "   \"id\": \"e1f2a3b4\",\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-26T12:54:02.599353359Z\",\n",
    "     \"start_time\": \"2026-03-26T12:54:02.499799956Z\"\n",
    "    }\n",
    "   },\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"data\": {\n",
    "      \"image/png\": \"\",\n",
    "      \"text/plain\": [\n",
    "       \"<Figure size 600x300 with 1 Axes>\"\n",
    "      ]\n",
    "     },\n",
    "     \"jetTransient\": {\n",
    "      \"display_id\": null\n",
    "     },\n",
    "     \"metadata\": {},\n",
    "     \"output_type\": \"display_data\"\n",
    "    }\n",
    "   ],\n",
    "   \"source\": [\n",
    "    \"rng_data = np.random.default_rng(SEED)\\n\",\n",
    "    \"n_each = 120\\n\",\n",
    "    \"x_left = rng_data.uniform(-4, -1, n_each)\\n\",\n",
    "    \"x_right = rng_data.uniform(1, 4, n_each)\\n\",\n",
    "    \"X_gap = np.concatenate([x_left, x_right]).reshape(-1, 1)\\n\",\n",
    "    \"y_gap = X_gap.ravel() ** 3 + rng_data.normal(0, 3, len(X_gap))\\n\",\n",
    "    \"\\n\",\n",
    "    \"X_train_reg, X_test_reg, y_train_reg, y_test_reg = train_test_split(X_gap, y_gap, test_size=0.3, random_state=SEED)\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.figure(figsize=(6, 3))\\n\",\n",
